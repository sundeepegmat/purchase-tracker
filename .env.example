# .env.example — add these as environment variables in Coolify dashboard

# e-GMAT Student Database API
EGMAT_API_URL=https://srv1079050.hstgr.cloud/student-db-mcp/
EGMAT_API_KEY=your-api-key-here

# Anthropic API (for AI-powered name guessing from email addresses)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Database path (default works in Docker)
DB_PATH=/app/data/purchase_tracker.db

# Refresh interval in minutes
REFRESH_INTERVAL_MINUTES=30
